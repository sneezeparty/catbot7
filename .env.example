# Cat Bot config. Copy to `.env` and fill in the values you need.
# `.env` is gitignored. config.py loads this file on import; shell env
# vars override these, so one-off prefixes like `voting_enabled=0 python
# bot.py` still work.
#
# Only TOKEN and psql_password are strictly required. Everything else
# is optional — leaving a var unset disables the feature it gates.

# --- required ---

# Discord bot token from https://discord.com/developers/applications
TOKEN=
# Postgres password for the `cat_bot` user
psql_password=
# Postgres port. Use 5433 if you spun up the DB with setup-pg.sh
psql_port=5432
# psql_host=127.0.0.1

# --- top.gg integration ---

# top.gg v1 API token. Powers the vote-replay polling loop (which lets
# the bot detect votes without exposing port 8069 to the internet),
# server-count metric posting, and the command-list upload.
top_gg_modern_token=
# top.gg webhook HMAC secret. If unset, the public aiohttp server on
# 0.0.0.0:8069 is not started at all. You only need this if you want
# realtime vote ingestion via webhook instead of 5-min polling.
# webhook_verify=
# Top.gg voting on/off. Defaults to "1" (on). Set "0" to disable
# /vote, the vote battlepass quest, the catch-message vote button,
# the webhook route, and the vote-replay loop.
# voting_enabled=1

# --- optional features ---

# Sentry DSN for error reporting
# sentry_dsn=
# Wordnik API key. Without it `/define` is unregistered and its
# battlepass quest auto-skips.
# wordnik_api_key=
# Enable the /store Discord-monetization command (default "0").
# store_enabled=0
# Invite to your support / community Discord. Used wherever the
# upstream bot used to link to its own server.
# support_invite=
# Discord ID of the bot owner — the only account allowed to run cat!* backdoors.
# Defaults to 0 (fail-closed) if unset; also overridden at runtime by the
# Discord application owner. Set this to your own id.
# owner_id=

# --- channel IDs (optional) ---

# backup_channel_id=
# donor_channel_id=
# rain_channel_id=
# ids allowed to trigger the cat!rain fulfillment hook besides the owner
# (comma/space-separated), e.g. your payment-automation bot/webhook id.
# rain_automation_ids=
# Discord user ids excluded from the dashboard's coins-in-circulation total/graph
# (comma/space-separated) — admin-granted/test wallets. Display-only.
# economy_outlier_user_ids=
